# Dependency directories (never commit node_modules)
node_modules/
backend/node_modules/
frontend/node_modules/

# Local configuration and environment variables
.env
backend/.env
frontend/.env

# Local JSON database storage (keeps your dev database separate from others)
backend/.data/
.data/

# Log files (email logs and system logs)
backend/logs/
*.log

# Production build outputs
frontend/dist/
dist/

# OS metadata
.DS_Store
Thumbs.db
